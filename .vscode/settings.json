{
    "git.ignoreLimitWarning": true,
    "chat.tools.terminal.autoApprove": {
        "npx tsc": true,
        "ForEach-Object": true,
        "/^npx eslint src$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^npx eslint src --format json$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^npx eslint src --format stylish$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^npx eslint src --debug$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^npx eslint src --max-warnings 0$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "npm install": true,
        "npm run db:reset": true,
        "npx supabase db push": true,
        "npx supabase db query": true,
        "npx eslint": true,
        "npx next": true,
        "/^npm -v; node -v$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "npx supabase": true,
        "npm run lint:fix": true,
        "/^npm run lint:fix -- --format json$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^npm run lint:fix -- --format stylish$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^npm run lint:fix -- --max-warnings 0$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "npm run lint:check": true,
        "tsc": true
    }
}