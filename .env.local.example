NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
ADMIN_USER_IDS=
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_GOOGLE_SECRET=

# Wompi payments (https://docs.wompi.co/docs/colombia/widget-checkout-web/)
# Public key — safe to expose. Use pub_test_ for sandbox, pub_prod_ for production.
NEXT_PUBLIC_WOMPI_PUBLIC_KEY=pub_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Integrity secret — server-side only, NEVER expose client-side.
WOMPI_INTEGRITY_SECRET=

# Supabase service role — server-side only, NEVER expose to client or MCP layer
SUPABASE_SERVICE_ROLE_KEY=

# AI Assistant
# DeepSeek (OpenAI-compatible API)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# Shared secret — WhatsApp bot must send this in the X-Assistant-Secret header
ASSISTANT_SECRET=
# Limited Postgres connection for the MCP server (assistant_bot role, no service role)
# Format: postgresql://assistant_bot:<password>@db.<ref>.supabase.co:5432/postgres
ASSISTANT_DB_URL=
# Password for the assistant_bot Postgres role — used by db:reset to set it automatically
ASSISTANT_BOT_PASSWORD=
