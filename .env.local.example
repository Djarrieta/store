# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
# Server-side only — bypasses RLS. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
# Database password — used by `npm run db:reset` (Supabase CLI remote queries)
SUPABASE_DB_PASSWORD=<database-password>

# ── Auth ─────────────────────────────────────────────────────────────────────
# Comma-separated UUIDs — granted admin on db:reset
ADMIN_USER_IDS=<uuid1>,<uuid2>

# ── Dev login (local only) ──────────────────────────────────────────────────
# Used by `npm run db:reset` (supabase/seed-dev-user.js) to (re)create a user
# with email+password, and by the "Dev login" button on /login (shown only
# when NODE_ENV !== "production" AND both NEXT_PUBLIC_* vars are set).
# Do NOT set these in production.
DEV_USER_EMAIL=dev@local.test
DEV_USER_PASSWORD=devpassword
NEXT_PUBLIC_DEV_USER_EMAIL=dev@local.test
NEXT_PUBLIC_DEV_USER_PASSWORD=devpassword

# ── Payments (Wompi) ─────────────────────────────────────────────────────────
# https://docs.wompi.co/docs/colombia/widget-checkout-web/
# Use pub_test_ / prv_integrity_test_ for sandbox; pub_prod_ / prv_integrity_prod_ for production.
NEXT_PUBLIC_WOMPI_PUBLIC_KEY=pub_test_<key>
# Server-side only — NEVER expose client-side.
WOMPI_INTEGRITY_SECRET=<integrity-secret>

# ── AI Assistant ─────────────────────────────────────────────────────────────
# DeepSeek (OpenAI-compatible API — https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-<key>
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# Shared secret — clients must send this in the X-Assistant-Secret header
ASSISTANT_SECRET=<random-secret>

# ── Theme ─────────────────────────────────────────────────────────────────────
# UI theme: "ten-lemmon" | "3d-cases" | "clean-slate"
THEME=ten-lemmon
