# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
# Server-side only — bypasses RLS. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Auth ─────────────────────────────────────────────────────────────────────
# Comma-separated UUIDs — granted admin on db:reset
ADMIN_USER_IDS=<uuid1>,<uuid2>
# ── Payments (Wompi) ─────────────────────────────────────────────────────────
# https://docs.wompi.co/docs/colombia/widget-checkout-web/
# Use pub_test_ / prv_integrity_test_ for sandbox; pub_prod_ / prv_integrity_prod_ for production.
NEXT_PUBLIC_WOMPI_PUBLIC_KEY=pub_test_<key>
# Server-side only — NEVER expose client-side.
WOMPI_INTEGRITY_SECRET=<integrity-secret>

# ── AI Assistant ─────────────────────────────────────────────────────────────
# DeepSeek (OpenAI-compatible API — https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-<key>
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# Shared secret — clients must send this in the X-Assistant-Secret header
ASSISTANT_SECRET=<random-secret>
# Limited Postgres connection for the MCP server (assistant_bot role, no service role)
# Format: postgresql://assistant_bot.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
ASSISTANT_DB_URL=postgresql://assistant_bot.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Password for the assistant_bot Postgres role — set automatically on db:reset
ASSISTANT_BOT_PASSWORD=<password>
